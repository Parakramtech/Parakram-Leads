# SMTP / Email (optional - Gmail app password recommended)
SMTP_HOST=${SMTP_HOST}
SMTP_PORT=${SMTP_PORT}
SMTP_USER=${SMTP_USER}
SMTP_PASSWORD=${SMTP_PASSWORD}
SMTP_FROM=${SMTP_FROM}

# Twilio (optional - for SMS alerts)
TWILIO_ACCOUNT_SID=${TWILIO_ACCOUNT_SID}
TWILIO_AUTH_TOKEN=${TWILIO_AUTH_TOKEN}
TWILIO_PHONE_NUMBER=${TWILIO_PHONE_NUMBER}

# WhatsApp Business API (optional - uses self-hosted Baileys bridge by default)
WHATSAPP_API_KEY=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BRIDGE_URL=http://whatsapp_bridge:4000

# Personal Alert Email
PERSONAL_ALERT_PHONE=
PERSONAL_ALERT_EMAIL=${PERSONAL_ALERT_EMAIL}

# Server
PUBLIC_API_URL=https://api-leads.getparakram.in/api/v1

# CORS - frontend URL must be whitelisted
WHITELISTED_ORIGINS=https://leads.getparakram.in

# Debug
DEBUG=false
