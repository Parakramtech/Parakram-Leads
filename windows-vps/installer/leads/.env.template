# Database
DB_PASSWORD=${DB_PASSWORD}
DATABASE_URL=postgresql+asyncpg://sigma:${DB_PASSWORD}@postgres:5432/sigma_leads
DATABASE_URL_SYNC=postgresql://sigma:${DB_PASSWORD}@postgres:5432/sigma_leads

# Redis
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
