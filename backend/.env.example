# Parakram Lead Intelligence - Environment Configuration

# Database
DATABASE_URL=postgresql+asyncpg://sigma:sigma@postgres:5432/sigma_leads
DATABASE_URL_SYNC=postgresql://sigma:sigma@postgres:5432/sigma_leads
DB_PASSWORD=sigma

# Redis
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Security
SECRET_KEY=your-secret-key-change-in-production

# OpenAI / LLM (optional - all services work offline)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# SMTP / Email (optional for email outreach)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=lead@parakram.ai

# Twilio (optional for SMS alerts)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# WhatsApp Business API (optional - use Baileys bridge instead)
WHATSAPP_API_KEY=
WHATSAPP_PHONE_NUMBER_ID=

# Personal Alerts
PERSONAL_ALERT_PHONE=
PERSONAL_ALERT_EMAIL=

# LinkedIn Automation (optional)
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=

# Server (for production deployment)
SERVER_IP=
PUBLIC_API_URL=

# Scraping Proxy (optional - prevents IP bans)
SCRAPING_PROXY_URL=

# Celery
CELERY_WORKER_CONCURRENCY=4

# Sentry (optional error tracking)
SENTRY_DSN=

# Debug
DEBUG=false
